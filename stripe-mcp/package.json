{
  "name": "@guillaumecode2012/stripe-mcp",
  "version": "1.0.0",
  "description": "The most complete MCP server for Stripe — manage customers, subscriptions, invoices, and analytics with natural language",
  "keywords": [
    "stripe",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "claude",
    "cursor",
    "payments",
    "saas"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stripe-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "stripe": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "prettier": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
